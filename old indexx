            .faq-tab-navigation { justify-content: flex-start; overflow-x: auto; white-space: nowrap; padding-bottom: 12px; -webkit-overflow-scrolling: touch; }
            .faq-nav-btn { padding: 8px 18px; font-size: 13.5px; }
            .faq-action-banner { flex-direction: column; align-items: flex-start; padding: 24px 20px; }
            .faq-action-btn { width: 100%; text-align: center; }
        }
    </style>
