        const toggleButton = document.getElementById('theme-toggle');
        const currentTheme = localStorage.getItem('theme') || 'light';
        document.documentElement.setAttribute('data-theme', currentTheme);
        toggleButton.textContent = currentTheme === 'dark' ? 'Light Mode' : 'Dark Mode';

        toggleButton.addEventListener('click', () => {
            const nextTheme = document.documentElement.getAttribute('data-theme') === 'dark' ? 'light' : 'dark';
            document.documentElement.setAttribute('data-theme', nextTheme);
            localStorage.setItem('theme', nextTheme);
            toggleButton.textContent = nextTheme === 'dark' ? 'Light Mode' : 'Dark Mode';
        });

        // Tab Component Routing Engine
        const tabButtons = document.querySelectorAll('.faq-nav-btn');
        const panels = document.querySelectorAll('.faq-topic-panel');

        tabButtons.forEach(button => {
            button.addEventListener('click', () => {
                tabButtons.forEach(btn => btn.classList.remove('active'));
                panels.forEach(panel => panel.classList.remove('visible'));

                button.classList.add('active');
                const targetId = `faq-panel-${button.getAttribute('data-faq-tab')}`;
                const targetPanel = document.getElementById(targetId);
                
                if (targetPanel) {
                    targetPanel.classList.add('visible');
                }
            });
        });
    </script>
</body>
</html>