            top: 0;
            z-index: 100;
        }
        .nav-wrapper {
            display: flex;
            justify-content: space-between;
            align-items: center;
            height: 70px;
        }
        .logo {
            font-size: 22px;
            font-weight: 800;
            color: var(--text-title);
