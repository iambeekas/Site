        .faq-action-text p { color: #94a3b8; font-size: 14.5px; }
        .faq-action-btn { padding: 12px 28px; background: var(--brand-primary); color: #ffffff; font-weight: 700; font-size: 14px; border: none; border-radius: 6px; cursor: pointer; text-decoration: none; white-space: nowrap; transition: background 0.2s ease; }
        .faq-action-btn:hover { background: var(--brand-primary-hover); }

        /* Footer Reset */
        footer { background: var(--surface-card); padding: 30px 0; border-top: 1px solid var(--border-color); text-align: center; font-size: 14px; color: var(--text-muted); }

        @keyframes faqFadeIn { from { opacity: 0; transform: translateY(6px); } to { opacity: 1; transform: translateY(0); } }

