        .faq-question-text { flex: 1; font-size: 15px; font-weight: 600; color: var(--text-title); line-height: 1.4; }
        .faq-icon-chevron { flex-shrink: 0; width: 18px; height: 18px; color: var(--text-muted); transition: transform 0.2s ease; }
        .faq-disclosure-card[open] .faq-icon-chevron { transform: rotate(180deg); color: var(--brand-primary); }

