        .faq-topic-panel { display: none; }
        .faq-topic-panel.visible { display: block; animation: faqFadeIn 0.35s ease; }
        .faq-panel-heading { font-size: 20px; font-weight: 700; color: var(--text-title); border-left: 4px solid var(--brand-primary); padding-left: 12px; margin: 35px 0 20px; }
